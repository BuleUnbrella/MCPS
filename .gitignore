# ==================== Python 核心忽略项（重点） ====================
# 字节码文件（运行产物）
__pycache__/
*.py[cod]
*$py.class

# 虚拟环境（绝对不上传）
venv/
env/
env/
myvenv/
.venv/
.env/
ENV/

# 编译产物
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 测试/覆盖率报告
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Jupyter 笔记本
.ipynb_checkpoints
*.ipynb

# 日志文件
*.log
logs/

# ==================== 通用忽略项（其他语言/工具） ====================
# 编辑器配置（VS Code/IDE）
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store  # Mac 系统文件
Thumbs.db  # Windows 系统文件

# Node.js 产物（如有前端/脚本依赖）
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tgz
dist-ssr/
*.local

# Shell 脚本临时文件
*.sh.swp
*.bash_history

# 编译型语言（C/C++/Java）
*.o
*.obj
*.class
*.jar
*.war
*.dll
*.exe

# 缓存/临时文件
*.tmp
*.temp
.cache/
.tmp/

# ==================== 项目自定义忽略项（可自行添加） ====================
# 例如：OpenCode 配置缓存
.opencode/
.config/opencode/cache/
# 本地配置文件（含敏感信息）
*.conf
*.ini
!example.ini  # 例外：示例配置可上传